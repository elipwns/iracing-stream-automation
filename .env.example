# iRacing
IRACING_CUST_ID=123456          # found on your iRacing profile page

# iRacing OAuth — obtain these when client registration reopens (email auth@iracing.com)
# First run with these set will open a browser for one-time login; tokens are cached locally.
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=          # leave blank if issued as a public client

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twitch chat bot
# Get TWITCH_TOKEN by logging into your bot account at: https://twitchapps.com/tmi/
TWITCH_TOKEN=oauth:...
TWITCH_CHANNEL=yourchannel

# OBS WebSocket (Tools > WebSocket Server Settings in OBS)
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=yourpassword

# Name of the Media Source in your Stream Outro scene that plays the goodbye video.
# When iRacing closes after a session, the monitor switches to Stream Outro and exits
# automatically once this source finishes playing.
OUTRO_MEDIA_SOURCE=GoodbyeVideo

# WLED - DIG-QUAD-V3 local IP
WLED_IP=192.168.1.xxx
